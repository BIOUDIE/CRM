{
   "buildCommand": "node ./node_modules/vite/bin/vite.js build",
  "installCommand": "npm ci",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/app",
      "dest": "/index.html"
    },
    {
      "src": "/app/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/",
      "dest": "/landing.html"
    }
  ]
}

